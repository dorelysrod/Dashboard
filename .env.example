# Variables de entorno — copia a .env.local (gitignored) y rellena con valores reales.
# Toda variable usada por la app se documenta aquí. NUNCA commitear secretos reales
# (solo placeholders/comentarios). El skill `secret-scanner` lo verifica.

# --- App ---
# NODE_ENV=development
# DEMO_MODE=1                  # fuerza el seed ficticio aunque Supabase esté configurado.
#   Úsalo en el deploy DEMO (preview de cómo se ve, solo lectura). El deploy de
#   PRODUCCIÓN va SIN esta variable + con Supabase real (clientes reales).
#   Los clientes reales se cargan a Supabase con supabase/seed.prod.local.sql
#   (gitignored, nunca al repo — GDPR).

# --- Supabase (dato único) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # solo server-side, nunca al cliente
#   Usada por la vista pública /maqueta/[token] para leer por token sin login
#   (omite RLS server-side). Sin ella, las maquetas caen a un store en memoria (dev).

# --- Maquetas (feature "maqueta") ---
# MAQUETA_TTL_DIAS=14          # días que vive el enlace público de una maqueta antes de expirar

# --- Harness IA (§5 del spec) ---
# AI_PROVIDER=manual           # "manual" (fase 1) | "anthropic" (fase 2)
# AI_MOCK=                     # "1" → respuestas simuladas (tests/dev, sin gastar ni tocar API)
#
# Fase 2 (AI_PROVIDER=anthropic) — backend Agent SDK (SUSCRIPCIÓN, como Claude Code):
#   Requiere el runtime de Claude Code + suscripción autenticada en el entorno.
#   Funciona LOCAL; en Vercel serverless estándar no (ahí usar manual o AI_MOCK=1).
# ANTHROPIC_MODEL=claude-sonnet-5   # modelo por defecto para las generaciones
# ANTHROPIC_RETRIES=3               # reintentos ante 429/5xx/errores de red
# ANTHROPIC_PRICES=                 # override de precios USD/MTok: "modelo=in:out,otro=in:out"
#   Nota: la suscripción NO usa ANTHROPIC_API_KEY; un token sk-ant-oat suelto se ignora.
#
# Maqueta = EQUIPO DE DISEÑO (pipeline multi-agente al pulsar "Generar"):
# ANTHROPIC_MODEL_DISENO=claude-opus-4-8   # ux-dev/frontend-dev/refinar (calidad de diseño)
# ANTHROPIC_MODEL_REVISOR=claude-sonnet-5  # revisor design-system + auditor a11y (más barato)

# --- Fotos de la maqueta (royalty-free, SOLO el mock) ---
# PEXELS_API_KEY=              # opcional: habilita fotos reales embebidas (Pexels, gratis,
#   uso comercial sin atribución). Sin ella, los marcadores ⟦FOTO⟧ caen a un gradiente
#   de marca. NO se usa iStock (licenciado/con marca de agua); para iStock/Getty haría
#   falta su API con credenciales y licencia (añadir como otro proveedor en lib/maquetas/fotos.ts).

# --- Config de negocio (también vive en tabla `config` de Supabase) ---
# FX_MXN_EUR=0.05              # tipo de cambio editable

# --- Integraciones (stubs en fase 1 — dejar el seam, no cablear) ---
# Places / Brevo / Stripe / GA4-GSC-GBP / PDF — añadir keys en fase 2.

# --- Deployment (Vercel) ---
# VERCEL_TOKEN se configura como secret de GitHub Actions, no aquí.

# --- Portal de propuestas /p/[numero] (dominio separado del panel) ---
# LANDINGS_HOST=propuestas.tudominio.com   # si se define, ESE host solo sirve /p/* (oculta el panel)
# PORTAL_ACCESO_MINUTOS=30                   # vida de la cookie de acceso antes de re-pedir email+código
# PORTAL_SECRET=                             # secreto para firmar el acceso (fallback: service role key)
